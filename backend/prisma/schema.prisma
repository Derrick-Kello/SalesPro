// This is the Prisma schema for the POS system.
// It defines all the tables and their relationships.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Branch model - represents a retail location
model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  location  String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users           User[]
  sales           Sale[]
  expenses        Expense[]
  branchInventory BranchInventory[]
  warehouses      Warehouse[]
  transfersFrom   StockTransfer[]   @relation("FromBranch")
  transfersTo     StockTransfer[]   @relation("ToBranch")
  products        Product[]         @relation("ProductBranches")

  @@map("branches")
}

// Warehouse model - physical storage location
model Warehouse {
  id        Int      @id @default(autoincrement())
  name      String
  location  String?
  branchId  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  branch               Branch?               @relation(fields: [branchId], references: [id])
  transfersFrom        StockTransfer[]       @relation("FromWarehouse")
  transfersTo          StockTransfer[]       @relation("ToWarehouse")
  warehouseInventory   WarehouseInventory[]
  stockReceipts        WarehouseStockReceipt[]

  @@map("warehouses")
}

// Log of goods received into a warehouse (purchase / intake) for audit and reporting
model WarehouseStockReceipt {
  id                Int      @id @default(autoincrement())
  warehouseId       Int
  productId         Int
  quantity          Int
  unitCostSnapshot  Float    @default(0)
  lineValueTotal    Float    @default(0)
  supplier          String?
  note              String?
  receivedById      Int
  createdAt         DateTime @default(now())

  warehouse  Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  receivedBy User      @relation(fields: [receivedById], references: [id])

  @@index([warehouseId, createdAt])
  @@map("warehouse_stock_receipts")
}

// Stock held at a warehouse (isolated from branch retail stock until transferred)
model WarehouseInventory {
  id             Int      @id @default(autoincrement())
  warehouseId    Int
  productId      Int
  quantity       Int      @default(0)
  lowStockAlert  Int      @default(10)
  supplier       String?

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@map("warehouse_inventory")
}

// BranchInventory - stock per product per branch
model BranchInventory {
  id            Int      @id @default(autoincrement())
  branchId      Int
  productId     Int
  quantity      Int      @default(0)
  lowStockAlert Int      @default(10)
  supplier      String?

  branch  Branch  @relation(fields: [branchId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
  @@map("branch_inventory")
}

// StockTransfer - record of stock movement between branches/warehouses
model StockTransfer {
  id               Int      @id @default(autoincrement())
  productId        Int
  quantity         Int
  costPrice        Float    @default(0)
  unitPrice        Float    @default(0)
  totalValue       Float    @default(0)
  fromBranchId     Int?
  fromWarehouseId  Int?
  toBranchId       Int?
  toWarehouseId    Int?
  transferredById  Int
  note             String?
  createdAt        DateTime @default(now())

  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromBranch     Branch?   @relation("FromBranch", fields: [fromBranchId], references: [id])
  fromWarehouse  Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toBranch       Branch?   @relation("ToBranch", fields: [toBranchId], references: [id])
  toWarehouse    Warehouse? @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  transferredBy  User      @relation(fields: [transferredById], references: [id])

  @@map("stock_transfers")
}

// Users who can log into the system - admins, managers, and cashiers
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  fullName  String
  role      String   @default("CASHIER")
  isActive  Boolean  @default(true)
  branchId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch        Branch?         @relation(fields: [branchId], references: [id])
  sales         Sale[]
  stockTransfers StockTransfer[]
  warehouseStockReceipts WarehouseStockReceipt[]

  @@map("users")
}

// Built-in roles: ADMIN, MANAGER, CASHIER
// Custom roles are stored as strings and managed via the Settings table

// Every product that can be sold in the store
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  variant     String   @default("Standard")
  category    String
  price       Float
  costPrice   Float     @default(0)
  barcode     String?  @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory          Inventory?
  branchInventory    BranchInventory[]
  warehouseInventory WarehouseInventory[]
  warehouseStockReceipts WarehouseStockReceipt[]
  saleItems          SaleItem[]
  stockTransfers     StockTransfer[]
  branches           Branch[]           @relation("ProductBranches")

  @@unique([name, variant])
  @@map("products")
}

// Tracks how much stock we have for each product
model Inventory {
  id            Int      @id @default(autoincrement())
  productId     Int      @unique
  quantity      Int      @default(0)
  lowStockAlert Int      @default(10)
  supplier      String?
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

// Customers who shop at the store
model Customer {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String?  @unique
  email        String?  @unique
  address      String?
  loyaltyPoints Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales Sale[]

  @@map("customers")
}

// A single sale transaction
model Sale {
  id            Int           @id @default(autoincrement())
  userId        Int
  customerId    Int?
  branchId      Int?
  totalAmount   Float
  discount      Float         @default(0)
  tax           Float         @default(0)
  shipping      Float         @default(0)
  grandTotal    Float
  status        SaleStatus    @default(COMPLETED)
  createdAt     DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id])
  customer  Customer? @relation(fields: [customerId], references: [id])
  branch    Branch?   @relation(fields: [branchId], references: [id])
  saleItems SaleItem[]
  payment   Payment?

  @@map("sales")
}

enum SaleStatus {
  PENDING
  COMPLETED
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

// Each line item inside a sale
model SaleItem {
  id        Int   @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int
  unitPrice Float
  subtotal  Float

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

// Payment record for each completed sale
model Payment {
  id            Int           @id @default(autoincrement())
  saleId        Int           @unique
  method        PaymentMethod
  amountPaid    Float
  change        Float         @default(0)
  reference     String?
  createdAt     DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id])

  @@map("payments")
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  CARD
  PAYSTACK
}

// Suppliers who provide products to the store
model Supplier {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String?
  email       String?
  address     String?
  company     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("suppliers")
}

// Expense categories
model ExpenseCategory {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())

  expenses  Expense[]

  @@map("expense_categories")
}

// Key-value settings store (permissions, app config, etc.)
model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("settings")
}

// Business expenses
model Expense {
  id          Int             @id @default(autoincrement())
  title       String
  amount      Float
  categoryId  Int
  branchId    Int?
  note        String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  branch      Branch?         @relation(fields: [branchId], references: [id])

  @@map("expenses")
}
